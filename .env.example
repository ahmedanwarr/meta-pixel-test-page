# Meta Pixel + CAPI — environment variables
# Copy this to .env and fill in your values

# ── Meta ──────────────────────────────────────────────────────────────────────
META_PIXEL_ID=your_pixel_id_here
META_CAPI_ACCESS_TOKEN=your_capi_system_user_token_here

# Only needed while testing via Events Manager Test Events tab
META_TEST_EVENT_CODE=TEST12345

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins — set to your landing page domain in prod
# Use * only for local dev
ALLOWED_ORIGINS=*
